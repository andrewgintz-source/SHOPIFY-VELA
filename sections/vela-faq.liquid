{% comment %}VELA — FAQ{% endcomment %}
<style>
  #vfaq-{{ section.id }}{font-family:'DM Sans',system-ui,sans-serif;padding:6rem 5%;background:linear-gradient(150deg,#7A4A9A,#A568C0,#C190D0)}
  #vfaq-{{ section.id }} .vfaq-in{max-width:760px;margin:0 auto}
  #vfaq-{{ section.id }} .vfaq-ey{font-size:0.62rem;font-weight:700;letter-spacing:0.26em;text-transform:uppercase;color:rgba(255,255,255,0.65);display:block;margin-bottom:1.2rem;text-align:center}
  #vfaq-{{ section.id }} .vfaq-h2{font-family:'Cormorant Garamond',Georgia,serif;font-size:clamp(2rem,4vw,3.2rem);font-weight:300;color:#fff;text-align:center;margin:0 0 3rem}
  #vfaq-{{ section.id }} .vfaq-item{border-bottom:1px solid rgba(255,255,255,0.2)}
  #vfaq-{{ section.id }} .vfaq-q{width:100%;background:none;border:none;text-align:left;padding:1.4rem 0;font-size:0.97rem;font-weight:600;color:#fff;cursor:pointer;display:flex;justify-content:space-between;align-items:center;font-family:'DM Sans',sans-serif}
  #vfaq-{{ section.id }} .vfaq-icon{transition:transform 0.3s;color:#C190D0;font-size:1.2rem;flex-shrink:0}
  #vfaq-{{ section.id }} .vfaq-a{max-height:0;overflow:hidden;transition:max-height 0.4s cubic-bezier(0.22,1,0.36,1)}
  #vfaq-{{ section.id }} .vfaq-item.open .vfaq-a{max-height:400px}
  #vfaq-{{ section.id }} .vfaq-item.open .vfaq-icon{transform:rotate(45deg)}
  #vfaq-{{ section.id }} .vfaq-ap{padding:0 0 1.4rem;font-size:0.92rem;line-height:1.76;color:rgba(255,255,255,0.7)}
</style>
<div id="vfaq-{{ section.id }}">
  <div class="vfaq-in">
    <span class="vfaq-ey">{{ section.settings.eyebrow | default: 'FAQ' }}</span>
    <h2 class="vfaq-h2">{{ section.settings.heading | default: 'Common questions' }}</h2>
    {%- for block in section.blocks -%}
      <div class="vfaq-item" {{ block.shopify_attributes }}>
        <button class="vfaq-q">{{ block.settings.question }}<span class="vfaq-icon">+</span></button>
        <div class="vfaq-a"><p class="vfaq-ap">{{ block.settings.answer }}</p></div>
      </div>
    {%- endfor -%}
  </div>
</div>
<script>
document.querySelectorAll('#vfaq-{{ section.id }} .vfaq-q').forEach(function(btn){
  btn.addEventListener('click',function(){
    var item=this.closest('.vfaq-item');
    var open=item.classList.contains('open');
    document.querySelectorAll('#vfaq-{{ section.id }} .vfaq-item.open').forEach(function(el){el.classList.remove('open');});
    if(!open)item.classList.add('open');
  });
});
</script>
{% schema %}
{"name":"Vela FAQ","tag":"section","class":"section","settings":[{"type":"text","id":"eyebrow","label":"Eyebrow","default":"FAQ"},{"type":"text","id":"heading","label":"Heading","default":"Common questions"}],"blocks":[{"type":"faq","name":"Question","settings":[{"type":"text","id":"question","label":"Question","default":"How long until I feel results?"},{"type":"textarea","id":"answer","label":"Answer","default":"Most customers notice a difference within 20–40 minutes of their first dose. For deeper, cumulative effects on sleep quality and stress resilience, allow 2–4 weeks of consistent daily use."}]}],"presets":[{"name":"Vela FAQ","blocks":[{"type":"faq","settings":{"question":"How long until I feel results?","answer":"Most customers notice a difference within 20–40 minutes of their first dose. For deeper cumulative effects allow 2–4 weeks of consistent daily use."}},{"type":"faq","settings":{"question":"How do I take Reishi Calm Drops?","answer":"Place one full dropper (1ml) under your tongue, hold for 30–60 seconds, then swallow. Best taken in the evening or during high-stress moments."}},{"type":"faq","settings":{"question":"Is it safe to take every day?","answer":"Yes. All ingredients are well-studied adaptogens with strong safety profiles for daily long-term use. No dependency or tolerance buildup."}},{"type":"faq","settings":{"question":"Will it make me drowsy?","answer":"No. Reishi Calm Drops are designed to promote calm without sedation. You can take them during the day without feeling foggy or tired."}}]}]}
{% endschema %}
