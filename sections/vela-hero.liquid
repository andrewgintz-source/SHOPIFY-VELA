{% comment %}
  VELA — Animated Hero Section
  Pain point: Stress & overwhelm
  Animations: orbs, word reveal, mouse parallax, shimmer, counter
{% endcomment %}

{{ 'vela-hero.css' | asset_url | stylesheet_tag }}

<section id="vela-hero-{{ section.id }}" aria-label="Vela Hero">

  <!-- Animated orbs -->
  <div class="vela-hero__orbs" aria-hidden="true">
    <div class="vela-orb vela-orb--1"></div>
    <div class="vela-orb vela-orb--2"></div>
    <div class="vela-orb vela-orb--3"></div>
    <div class="vela-orb vela-orb--4"></div>
  </div>

  <div class="vela-hero__inner">

    <!-- Left: Content -->
    <div class="vela-hero__content">

      <div class="vela-hero__eyebrow">
        <span class="vela-hero__eyebrow-dot"></span>
        {{ section.settings.eyebrow | default: 'Introducing Vela' }}
      </div>

      <h1 class="vela-hero__headline" id="vela-headline-{{ section.id }}">
        {{ section.settings.headline | default: 'Modern life is relentless. Your body remembers.' }}
      </h1>

      <p class="vela-hero__sub">
        {{ section.settings.subheadline | default: 'Deadlines. Notifications. The weight of everything. Your nervous system has been running on empty — and it's <strong>paying the price.</strong>' }}
      </p>

      <div class="vela-hero__divider"></div>

      <p class="vela-hero__intro">
        {{ section.settings.intro | default: 'Reishi Calm Drops is a daily adaptogen tincture crafted to quiet the noise — supporting your body\'s natural stress response so you can finally breathe again.' }}
      </p>

      <!-- Social proof -->
      <div class="vela-hero__proof">
        <div class="vela-hero__stars" aria-label="5 stars">
          {%- for i in (1..5) -%}
            <svg class="vela-hero__star" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M10 1l2.39 4.84 5.34.78-3.86 3.76.91 5.32L10 13.27l-4.78 2.51.91-5.32L2.27 6.62l5.34-.78z"/>
            </svg>
          {%- endfor -%}
        </div>
        <span class="vela-hero__proof-text">
          <span class="vela-hero__proof-count" data-count="{{ section.settings.review_count | default: 2847 }}">0</span>
          &nbsp;reviews
        </span>
        <div class="vela-hero__proof-divider" aria-hidden="true"></div>
        <span class="vela-hero__proof-badge">{{ section.settings.proof_badge | default: 'Natural ingredients' }}</span>
      </div>

      <!-- CTA -->
      <div class="vela-hero__cta-wrap">
        <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="vela-hero__cta">
          {{ section.settings.cta_text | default: 'Shop now' }}
          <svg class="vela-hero__cta-arrow" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M1 7h12M7.5 1.5L13 7l-5.5 5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        {%- if section.settings.learn_url != blank -%}
          <a href="{{ section.settings.learn_url }}" class="vela-hero__learn">
            {{ section.settings.learn_text | default: 'Learn how it works' }}
          </a>
        {%- endif -%}
      </div>

    </div><!-- /content -->

    <!-- Right: Product visual -->
    <div class="vela-hero__visual" id="vela-visual-{{ section.id }}" aria-hidden="true">

      <!-- Glow + orbits -->
      <div class="vela-hero__product-glow"></div>
      <div class="vela-hero__orbit"></div>
      <div class="vela-hero__orbit vela-hero__orbit--2"></div>

      <!-- Product image -->
      <div class="vela-hero__product-wrap" id="vela-product-{{ section.id }}">
        {%- if section.settings.product_image != blank -%}
          {{ section.settings.product_image | image_url: width: 600 | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            class: 'vela-hero__product-img',
            alt: section.settings.product_image.alt | escape
          }}
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'vela-hero__product-img' }}
        {%- endif -%}
      </div>

      <!-- Floating badge 1 -->
      <div class="vela-hero__badge vela-hero__badge--1">
        <span class="vela-hero__badge-label">Serving size</span>
        <span class="vela-hero__badge-value">1ml <span>/ daily</span></span>
      </div>

      <!-- Floating badge 2 -->
      <div class="vela-hero__badge vela-hero__badge--2">
        <span class="vela-hero__badge-label">Key ingredient</span>
        <span class="vela-hero__badge-value">Reishi <span>extract</span></span>
      </div>

    </div><!-- /visual -->

  </div><!-- /inner -->

  <!-- Scroll indicator -->
  <div class="vela-hero__scroll" aria-hidden="true">
    <span class="vela-hero__scroll-text">Scroll</span>
    <div class="vela-hero__scroll-line"></div>
  </div>

</section>

<script>
(function () {
  'use strict';

  const heroId = 'vela-hero-{{ section.id }}';

  /* ── Word-by-word headline animation ── */
  function initHeadline() {
    const el = document.getElementById('vela-headline-{{ section.id }}');
    if (!el) return;

    const rawText = el.textContent;
    const words = rawText.trim().split(/\s+/);
    el.innerHTML = words.map((w, i) => {
      const isAccent = ['relentless.', 'relentless', 'calm', 'breathe', 'price.'].includes(w.toLowerCase());
      const cls = isAccent ? 'word word--accent' : 'word';
      const delay = (0.55 + i * 0.08).toFixed(2);
      return `<span class="${cls}" style="animation-delay:${delay}s">${w}</span> `;
    }).join('');
  }

  /* ── Review count-up ── */
  function initCounter() {
    const el = document.querySelector(`#${heroId} [data-count]`);
    if (!el) return;

    const target = parseInt(el.dataset.count, 10);
    const duration = 2200;
    const start = performance.now();

    function easeOut(t) { return 1 - Math.pow(1 - t, 3); }

    function tick(now) {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      el.textContent = Math.round(easeOut(progress) * target).toLocaleString();
      if (progress < 1) requestAnimationFrame(tick);
    }

    // Start counter when section enters viewport
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          setTimeout(() => requestAnimationFrame(tick), 2200);
          observer.disconnect();
        }
      });
    }, { threshold: 0.3 });

    const section = document.getElementById(heroId);
    if (section) observer.observe(section);
  }

  /* ── Mouse parallax on product ── */
  function initParallax() {
    const visual = document.getElementById('vela-visual-{{ section.id }}');
    const product = document.getElementById('vela-product-{{ section.id }}');
    if (!visual || !product) return;

    let animFrame;
    let targetX = 0, targetY = 0;
    let currentX = 0, currentY = 0;

    document.addEventListener('mousemove', (e) => {
      const vw = window.innerWidth;
      const vh = window.innerHeight;
      targetX = ((e.clientX / vw) - 0.5) * 22;
      targetY = ((e.clientY / vh) - 0.5) * 14;
    });

    function lerp(a, b, t) { return a + (b - a) * t; }

    function animate() {
      currentX = lerp(currentX, targetX, 0.06);
      currentY = lerp(currentY, targetY, 0.06);

      // Pause CSS float animation during parallax
      product.style.animationPlayState = 'paused';
      product.style.transform = `translate(${currentX}px, ${currentY}px)`;

      animFrame = requestAnimationFrame(animate);
    }

    animate();

    // Remove parallax on mobile
    if (window.matchMedia('(max-width: 989px)').matches) {
      cancelAnimationFrame(animFrame);
      product.style.transform = '';
      product.style.animationPlayState = 'running';
    }
  }

  /* ── Init ── */
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      initHeadline();
      initCounter();
      initParallax();
    });
  } else {
    initHeadline();
    initCounter();
    initParallax();
  }
})();
</script>

{% schema %}
{
  "name": "Vela Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Introducing Vela"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Main headline",
      "default": "Modern life is relentless. Your body remembers."
    },
    {
      "type": "richtext",
      "id": "subheadline",
      "label": "Sub-headline",
      "default": "<p>Deadlines. Notifications. The weight of everything. Your nervous system has been running on empty — and it's paying the price.</p>"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Product intro line",
      "default": "Reishi Calm Drops is a daily adaptogen tincture crafted to quiet the noise — supporting your body's natural stress response so you can finally breathe again."
    },
    {
      "type": "number",
      "id": "review_count",
      "label": "Review count",
      "default": 2847
    },
    {
      "type": "text",
      "id": "proof_badge",
      "label": "Trust badge text",
      "default": "Natural ingredients"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Primary CTA link"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Primary CTA text",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "learn_url",
      "label": "Secondary link URL"
    },
    {
      "type": "text",
      "id": "learn_text",
      "label": "Secondary link text",
      "default": "Learn how it works"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product image"
    }
  ],
  "presets": [
    {
      "name": "Vela Hero"
    }
  ]
}
{% endschema %}
