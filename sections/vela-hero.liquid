{% comment %}VELA — Dark Animated Hero{% endcomment %}

<style>
  #vh-{{ section.id }} {
    font-family: 'DM Sans', system-ui, sans-serif;
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, #2D1B45 0%, #1A0D2E 50%, #0D0618 100%);
    min-height: 100svh;
    display: flex;
    align-items: center;
  }
  #vh-{{ section.id }} .vh-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
    animation: vh-drift 8s ease-in-out infinite;
  }
  #vh-{{ section.id }} .vh-orb--a { width:520px;height:520px;background:rgba(193,144,208,0.35);top:-10%;left:-8%;animation-delay:0s; }
  #vh-{{ section.id }} .vh-orb--b { width:380px;height:380px;background:rgba(122,74,154,0.42);bottom:5%;right:2%;animation-delay:-3s; }
  #vh-{{ section.id }} .vh-orb--c { width:260px;height:260px;background:rgba(193,144,208,0.28);top:40%;left:38%;animation-delay:-5s; }
  @keyframes vh-drift { 0%,100%{transform:translateY(0) scale(1)} 50%{transform:translateY(-28px) scale(1.05)} }
  #vh-{{ section.id }} .vh-inner {
    position:relative;z-index:2;
    display:grid;grid-template-columns:1fr 1fr;align-items:center;
    max-width:1340px;margin:0 auto;padding:6rem 5%;gap:3rem;
    width:100%;box-sizing:border-box;
  }
  #vh-{{ section.id }} .vh-content {
    opacity:0;transform:translateY(22px);
    animation:vh-up 0.9s 0.1s cubic-bezier(0.22,1,0.36,1) forwards;
  }
  @keyframes vh-up { to{opacity:1;transform:translateY(0)} }
  #vh-{{ section.id }} .vh-eyebrow {
    display:inline-flex;align-items:center;gap:8px;
    font-size:0.62rem;font-weight:700;letter-spacing:0.28em;text-transform:uppercase;
    color:rgba(193,144,208,0.85);margin-bottom:1.6rem;
  }
  #vh-{{ section.id }} .vh-dot {
    width:6px;height:6px;border-radius:50%;background:#C190D0;
    animation:vh-pulse 2s ease-in-out infinite;
  }
  @keyframes vh-pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.5;transform:scale(0.7)} }
  #vh-{{ section.id }} .vh-headline {
    font-family:'Cormorant Garamond',Georgia,serif;
    font-size:clamp(2.8rem,5vw,5rem);
    font-weight:300;line-height:1.05;letter-spacing:-0.02em;
    color:#fff;margin:0 0 1.4rem;max-width:14ch;
  }
  #vh-{{ section.id }} .vh-headline em { color:#C190D0;font-style:italic; }
  #vh-{{ section.id }} .vh-body {
    font-size:0.97rem;line-height:1.78;color:rgba(255,255,255,0.55);
    margin:0 0 2.4rem;max-width:42ch;
  }
  #vh-{{ section.id }} .vh-row { display:flex;align-items:center;gap:1.2rem;flex-wrap:wrap; }
  #vh-{{ section.id }} .vh-btn {
    display:inline-flex;align-items:center;gap:8px;
    background:linear-gradient(135deg,#7A4A9A,#C190D0);
    color:#fff;font-size:0.82rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;
    text-decoration:none;padding:14px 28px;border-radius:100px;
    transition:transform 0.25s,box-shadow 0.25s;
    box-shadow:0 8px 32px rgba(193,144,208,0.3);
  }
  #vh-{{ section.id }} .vh-btn:hover { transform:translateY(-2px);box-shadow:0 14px 40px rgba(193,144,208,0.45); }
  #vh-{{ section.id }} .vh-link {
    font-size:0.82rem;color:rgba(255,255,255,0.5);text-decoration:none;
    border-bottom:1px solid rgba(255,255,255,0.2);padding-bottom:1px;
    transition:color 0.2s,border-color 0.2s;
  }
  #vh-{{ section.id }} .vh-link:hover { color:#C190D0;border-color:#C190D0; }
  #vh-{{ section.id }} .vh-proof {
    display:flex;align-items:center;gap:10px;margin-top:2rem;
    font-size:0.75rem;color:rgba(255,255,255,0.4);
  }
  #vh-{{ section.id }} .vh-stars { color:#C190D0;letter-spacing:1px; }
  #vh-{{ section.id }} .vh-visual {
    display:flex;justify-content:center;align-items:center;position:relative;
    opacity:0;transform:translateX(20px);
    animation:vh-slide 1s 0.35s cubic-bezier(0.22,1,0.36,1) forwards;
  }
  @keyframes vh-slide { to{opacity:1;transform:translateX(0)} }
  #vh-{{ section.id }} .vh-img {
    max-width:100%;max-height:520px;object-fit:contain;
    animation:vh-float 5s ease-in-out infinite;position:relative;z-index:2;
  }
  @keyframes vh-float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-16px)} }
  #vh-{{ section.id }} .vh-glow {
    position:absolute;width:340px;height:340px;border-radius:50%;
    background:radial-gradient(circle,rgba(193,144,208,0.35),transparent 70%);
  }
  @media(max-width:768px){
    #vh-{{ section.id }} .vh-inner { grid-template-columns:1fr;padding:5rem 6% 4rem; }
    #vh-{{ section.id }} .vh-visual { display:none; }
    #vh-{{ section.id }} .vh-headline { font-size:clamp(2.4rem,9vw,3.4rem); }
  }
</style>

<div id="vh-{{ section.id }}">
  <div class="vh-orb vh-orb--a" aria-hidden="true"></div>
  <div class="vh-orb vh-orb--b" aria-hidden="true"></div>
  <div class="vh-orb vh-orb--c" aria-hidden="true"></div>
  <div class="vh-inner">
    <div class="vh-content">
      {%- if section.settings.eyebrow != blank -%}
        <div class="vh-eyebrow"><span class="vh-dot" aria-hidden="true"></span>{{ section.settings.eyebrow }}</div>
      {%- endif -%}
      <h1 class="vh-headline">{{ section.settings.headline }}</h1>
      {%- if section.settings.description != blank -%}
        <p class="vh-body">{{ section.settings.description }}</p>
      {%- endif -%}
      <div class="vh-row">
        <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="vh-btn">
          {{ section.settings.cta_text | default: 'Shop Now' }}
        </a>
        {%- if section.settings.secondary_url != blank -%}
          <a href="{{ section.settings.secondary_url }}" class="vh-link">{{ section.settings.secondary_text | default: 'Learn more' }}</a>
        {%- endif -%}
      </div>
      <div class="vh-proof">
        <span class="vh-stars">★★★★★</span>
        <span>{{ section.settings.review_count | default: 2847 }} verified reviews</span>
      </div>
    </div>
    <div class="vh-visual" aria-hidden="true">
      <div class="vh-glow"></div>
      {%- if section.settings.product_image != blank -%}
        <img class="vh-img" src="{{ section.settings.product_image | image_url: width: 600 }}" alt="{{ section.settings.product_image.alt | escape }}" width="600" loading="eager">
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'vh-img' }}
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Vela Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text",         "id": "eyebrow",       "label": "Eyebrow",            "default": "Introducing Vela" },
    { "type": "textarea",     "id": "headline",      "label": "Headline",           "default": "Modern life is relentless. Your body remembers." },
    { "type": "textarea",     "id": "description",   "label": "Description",        "default": "Reishi Calm Drops — a daily adaptogen tincture crafted to quiet the noise." },
    { "type": "url",          "id": "cta_url",       "label": "Button URL" },
    { "type": "text",         "id": "cta_text",      "label": "Button text",        "default": "Shop Reishi Calm Drops" },
    { "type": "url",          "id": "secondary_url", "label": "Secondary link URL" },
    { "type": "text",         "id": "secondary_text","label": "Secondary link text","default": "Learn more" },
    { "type": "number",       "id": "review_count",  "label": "Review count",       "default": 2847 },
    { "type": "image_picker", "id": "product_image", "label": "Product image" }
  ],
  "presets": [{ "name": "Vela Hero" }]
}
{% endschema %}
