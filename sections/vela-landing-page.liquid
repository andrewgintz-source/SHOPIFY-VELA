{% comment %}
  VELA — Full Conversion Landing Page
  Sections: Hero → Pain Point → Solution → How It Works
            → Ingredients → Testimonials → FAQ → CTA
{% endcomment %}

<style>
/* ═══════════════════════════════════════════════════════════════
   VELA LANDING — BASE TOKENS
═══════════════════════════════════════════════════════════════ */
#vlp-{{ section.id }} {
  --lp-lavender:      #C190D0;
  --lp-lavender-soft: #F2E8F7;
  --lp-lavender-mid:  #DDB8EA;
  --lp-deep:          #7A4A9A;
  --lp-black:         #0A0810;
  --lp-charcoal:      #1E1A22;
  --lp-white:         #FFFFFF;
  --lp-stone:         #9B8FA3;
  --lp-cream:         #FAF8FC;
  --lp-font-h:        'Cormorant Garamond', Georgia, serif;
  --lp-font-b:        'DM Sans', system-ui, sans-serif;
  --lp-ease:          cubic-bezier(0.22, 1, 0.36, 1);
  font-family: var(--lp-font-b);
  color: var(--lp-charcoal);
  overflow-x: hidden;
}

/* Scroll-reveal base class */
#vlp-{{ section.id }} .lp-reveal {
  opacity: 0;
  transform: translateY(36px);
  transition: opacity 0.75s var(--lp-ease), transform 0.75s var(--lp-ease);
}
#vlp-{{ section.id }} .lp-reveal.lp-visible {
  opacity: 1;
  transform: translateY(0);
}
#vlp-{{ section.id }} .lp-reveal-left {
  opacity: 0;
  transform: translateX(-36px);
  transition: opacity 0.75s var(--lp-ease), transform 0.75s var(--lp-ease);
}
#vlp-{{ section.id }} .lp-reveal-left.lp-visible {
  opacity: 1;
  transform: translateX(0);
}
#vlp-{{ section.id }} .lp-reveal-right {
  opacity: 0;
  transform: translateX(36px);
  transition: opacity 0.75s var(--lp-ease), transform 0.75s var(--lp-ease);
}
#vlp-{{ section.id }} .lp-reveal-right.lp-visible {
  opacity: 1;
  transform: translateX(0);
}

/* Stagger delays */
#vlp-{{ section.id }} [data-delay="1"] { transition-delay: 0.08s; }
#vlp-{{ section.id }} [data-delay="2"] { transition-delay: 0.18s; }
#vlp-{{ section.id }} [data-delay="3"] { transition-delay: 0.28s; }
#vlp-{{ section.id }} [data-delay="4"] { transition-delay: 0.38s; }
#vlp-{{ section.id }} [data-delay="5"] { transition-delay: 0.48s; }

/* Section spacing */
#vlp-{{ section.id }} .lp-section {
  padding: 7rem 2rem;
}
#vlp-{{ section.id }} .lp-inner {
  max-width: 1200px;
  margin: 0 auto;
}
#vlp-{{ section.id }} .lp-eyebrow {
  display: inline-block;
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.26em;
  text-transform: uppercase;
  color: var(--lp-deep);
  margin-bottom: 1.2rem;
}
#vlp-{{ section.id }} .lp-eyebrow--light {
  color: rgba(255,255,255,0.6);
}
#vlp-{{ section.id }} .lp-h2 {
  font-family: var(--lp-font-h);
  font-size: clamp(2.4rem, 5vw, 4.4rem);
  font-weight: 300;
  line-height: 1.08;
  letter-spacing: -0.02em;
}
#vlp-{{ section.id }} .lp-h2--white { color: var(--lp-white); }
#vlp-{{ section.id }} .lp-h2--dark  { color: var(--lp-black); }
#vlp-{{ section.id }} .lp-body {
  font-size: 0.96rem;
  line-height: 1.76;
  color: var(--lp-stone);
}
#vlp-{{ section.id }} .lp-body--light { color: rgba(255,255,255,0.6); }

/* Button */
#vlp-{{ section.id }} .lp-btn {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-family: var(--lp-font-b);
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  border-radius: 100px;
  padding: 1.05rem 2.6rem;
  text-decoration: none;
  cursor: pointer;
  border: 2px solid transparent;
  transition: all 0.3s var(--lp-ease);
  position: relative;
  overflow: hidden;
}
#vlp-{{ section.id }} .lp-btn--dark {
  background: var(--lp-black);
  color: var(--lp-white);
  border-color: var(--lp-black);
}
#vlp-{{ section.id }} .lp-btn--dark:hover {
  background: var(--lp-deep);
  border-color: var(--lp-deep);
  transform: translateY(-2px);
  box-shadow: 0 12px 40px rgba(122,74,154,0.35);
}
#vlp-{{ section.id }} .lp-btn--white {
  background: var(--lp-white);
  color: var(--lp-black);
  border-color: var(--lp-white);
}
#vlp-{{ section.id }} .lp-btn--white:hover {
  background: var(--lp-lavender);
  color: var(--lp-white);
  border-color: var(--lp-lavender);
  transform: translateY(-2px);
  box-shadow: 0 12px 40px rgba(193,144,208,0.4);
}
#vlp-{{ section.id }} .lp-btn--outline {
  background: transparent;
  color: var(--lp-white);
  border-color: rgba(255,255,255,0.35);
}
#vlp-{{ section.id }} .lp-btn--outline:hover {
  background: var(--lp-white);
  color: var(--lp-black);
  border-color: var(--lp-white);
}
#vlp-{{ section.id }} .lp-btn svg {
  transition: transform 0.3s ease;
}
#vlp-{{ section.id }} .lp-btn:hover svg {
  transform: translateX(4px);
}
/* Shimmer */
#vlp-{{ section.id }} .lp-btn--shimmer::after {
  content: '';
  position: absolute;
  top: 0; left: -100%;
  width: 55%; height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.22), transparent);
  animation: lp-shimmer 2.6s ease-in-out infinite;
}
@keyframes lp-shimmer {
  0%   { left: -100%; }
  45%  { left: 140%; }
  100% { left: 140%; }
}

/* ═══════════════════════════════════════════════════════════════
   1. HERO
═══════════════════════════════════════════════════════════════ */
#vlp-hero-{{ section.id }} {
  position: relative;
  min-height: 100vh;
  background: var(--lp-black);
  display: flex;
  align-items: center;
  overflow: hidden;
}

/* Grain */
#vlp-hero-{{ section.id }}::before {
  content: '';
  position: absolute;
  inset: -50%;
  width: 200%; height: 200%;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size: 180px;
  opacity: 0.036;
  pointer-events: none;
  z-index: 1;
  animation: lp-grain 0.5s steps(1) infinite;
}
@keyframes lp-grain {
  0%  { transform: translate(0,0); }
  20% { transform: translate(-2%,-3%); }
  40% { transform: translate(3%,2%); }
  60% { transform: translate(-1%,4%); }
  80% { transform: translate(4%,-2%); }
}

/* Orbs */
.lp-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(90px);
  pointer-events: none;
  z-index: 0;
}
.lp-orb--a { width:640px; height:640px; background:radial-gradient(circle,#7A4A9A,transparent 70%); top:-15%; right:-5%; animation:lp-float-a 20s ease-in-out infinite; opacity:.85; }
.lp-orb--b { width:480px; height:480px; background:radial-gradient(circle,#C190D0,transparent 70%); bottom:-12%; left:28%; animation:lp-float-b 25s ease-in-out infinite; opacity:.7; }
.lp-orb--c { width:320px; height:320px; background:radial-gradient(circle,#DDB8EA,transparent 70%); top:22%; left:-4%; animation:lp-float-c 18s ease-in-out infinite; opacity:.6; }
@keyframes lp-float-a { 0%,100%{transform:translate(0,0) scale(1)} 33%{transform:translate(-28px,40px) scale(1.04)} 66%{transform:translate(18px,-28px) scale(.96)} }
@keyframes lp-float-b { 0%,100%{transform:translate(0,0) scale(1)} 40%{transform:translate(36px,-44px) scale(1.05)} 70%{transform:translate(-22px,28px) scale(.97)} }
@keyframes lp-float-c { 0%,100%{transform:translate(0,0) scale(1)} 50%{transform:translate(30px,22px) scale(1.06)} }

/* Hero inner */
.lp-hero-inner {
  position: relative;
  z-index: 2;
  width: 100%;
  max-width: 1240px;
  margin: 0 auto;
  padding: 6rem 2rem;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
  min-height: 100vh;
}

/* Hero content */
.lp-hero-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.26em;
  text-transform: uppercase;
  color: var(--lp-lavender);
  margin-bottom: 1.8rem;
  opacity: 0;
  animation: lp-up 0.7s 0.2s var(--lp-ease) forwards;
}
.lp-hero-dot { width:6px; height:6px; border-radius:50%; background:var(--lp-lavender); animation:lp-pulse 2s ease-in-out infinite; }
@keyframes lp-pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.4;transform:scale(.7)} }

.lp-hero-h1 {
  font-family: var(--lp-font-h);
  font-size: clamp(3.4rem, 6vw, 6.5rem);
  font-weight: 300;
  line-height: 1.0;
  letter-spacing: -0.03em;
  color: var(--lp-white);
  margin: 0 0 1.6rem;
}
.lp-hero-h1 .w {
  display: inline-block;
  opacity: 0;
  transform: translateY(28px);
  animation: lp-word 0.6s var(--lp-ease) forwards;
}
.lp-hero-h1 .w-accent { color: var(--lp-lavender); font-style: italic; }

.lp-hero-sub {
  font-size: 1rem;
  line-height: 1.68;
  color: rgba(255,255,255,0.52);
  max-width: 42ch;
  margin-bottom: 1.6rem;
  opacity: 0;
  animation: lp-up 0.7s 1.4s var(--lp-ease) forwards;
}
.lp-hero-sub strong { color: rgba(255,255,255,.88); font-weight:500; }

.lp-hero-line {
  width: 0; height: 1px;
  background: linear-gradient(90deg,var(--lp-lavender),transparent);
  margin-bottom: 1.6rem;
  animation: lp-line 0.9s 1.7s var(--lp-ease) forwards;
}
@keyframes lp-line { to { width:100px; } }

.lp-hero-desc {
  font-size: 0.88rem;
  color: rgba(255,255,255,.44);
  line-height: 1.74;
  max-width: 40ch;
  margin-bottom: 2.8rem;
  opacity: 0;
  animation: lp-up 0.7s 1.9s var(--lp-ease) forwards;
}

/* Proof row */
.lp-hero-proof {
  display: flex;
  align-items: center;
  gap: 1.2rem;
  flex-wrap: wrap;
  margin-bottom: 2.6rem;
  opacity: 0;
  animation: lp-up 0.7s 2.1s var(--lp-ease) forwards;
}
.lp-stars { display:flex; gap:3px; }
.lp-star  { width:14px; height:14px; fill:var(--lp-lavender); }
.lp-proof-text { font-size:.8rem; color:rgba(255,255,255,.55); }
.lp-proof-count { font-weight:700; color:rgba(255,255,255,.9); }
.lp-proof-sep   { width:1px; height:16px; background:rgba(255,255,255,.14); }
.lp-proof-pill  {
  font-size:.64rem; font-weight:700; letter-spacing:.12em; text-transform:uppercase;
  color:var(--lp-lavender);
  background:rgba(193,144,208,.12);
  border:1px solid rgba(193,144,208,.25);
  border-radius:100px; padding:.3rem .9rem;
}

.lp-hero-cta-row {
  display: flex;
  align-items: center;
  gap: 1.6rem;
  flex-wrap: wrap;
  opacity: 0;
  animation: lp-up 0.7s 2.3s var(--lp-ease) forwards;
}
.lp-hero-link {
  font-size:.76rem; color:rgba(255,255,255,.38);
  text-decoration:none;
  border-bottom:1px solid rgba(255,255,255,.15);
  padding-bottom:2px;
  transition:all .2s ease;
}
.lp-hero-link:hover { color:rgba(255,255,255,.75); border-color:rgba(255,255,255,.4); }

/* Hero visual */
.lp-hero-visual {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  opacity: 0;
  animation: lp-scale-in 1.2s 0.5s var(--lp-ease) forwards;
}
.lp-hero-glow {
  position:absolute; width:440px; height:440px; border-radius:50%;
  background:radial-gradient(circle,rgba(193,144,208,.2),transparent 70%);
  animation:lp-glow 5s ease-in-out infinite;
}
@keyframes lp-glow { 0%,100%{transform:scale(1);opacity:.8} 50%{transform:scale(1.14);opacity:1} }

.lp-orbit {
  position:absolute; border-radius:50%;
  border:1px solid rgba(193,144,208,.1);
}
.lp-orbit::after {
  content:''; position:absolute; border-radius:50%;
  width:8px; height:8px; top:-4px; left:50%;
  transform:translateX(-50%);
  background:var(--lp-lavender);
  box-shadow:0 0 12px var(--lp-lavender);
}
.lp-orbit--1 { width:380px;height:380px; animation:lp-spin 28s linear infinite; }
.lp-orbit--2 { width:480px;height:480px; animation:lp-spin 42s linear infinite reverse; border-color:rgba(122,74,154,.07); }
.lp-orbit--2::after { background:var(--lp-deep); box-shadow:0 0 10px var(--lp-deep); width:6px;height:6px;top:-3px; }
@keyframes lp-spin { from{transform:rotate(0deg)} to{transform:rotate(360deg)} }

.lp-hero-product {
  position:relative; z-index:2;
  animation:lp-float 7s ease-in-out infinite;
  will-change:transform;
}
@keyframes lp-float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-20px)} }
.lp-hero-product img,
.lp-hero-product svg {
  width:270px; height:auto;
  filter:drop-shadow(0 30px 80px rgba(122,74,154,.5)) drop-shadow(0 0 40px rgba(193,144,208,.22));
}

/* Hero badges */
.lp-hero-badge {
  position:absolute; z-index:3;
  background:rgba(255,255,255,.08);
  backdrop-filter:blur(14px);
  -webkit-backdrop-filter:blur(14px);
  border:1px solid rgba(255,255,255,.14);
  border-radius:14px; padding:.8rem 1.2rem;
  opacity:0; animation:lp-badge-in .8s var(--lp-ease) forwards;
}
.lp-hero-badge--1 { top:14%; right:-2%; animation-delay:1.7s; }
.lp-hero-badge--2 { bottom:20%; left:-5%; animation-delay:2s; }
.lp-badge-label { font-size:.58rem;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:rgba(255,255,255,.4);display:block;margin-bottom:3px; }
.lp-badge-val { font-family:var(--lp-font-h);font-size:1.3rem;font-weight:400;color:var(--lp-white);line-height:1; }
.lp-badge-val span { font-size:.68rem;font-family:var(--lp-font-b);color:rgba(255,255,255,.4);font-weight:400; }

/* Scroll cue */
.lp-scroll-cue {
  position:absolute; bottom:2.4rem; left:50%; transform:translateX(-50%);
  z-index:2; display:flex; flex-direction:column; align-items:center; gap:6px;
  opacity:0; animation:lp-up .6s 3.2s forwards;
}
.lp-scroll-label { font-size:.58rem;font-weight:700;letter-spacing:.24em;text-transform:uppercase;color:rgba(255,255,255,.22); }
.lp-scroll-bar { width:1px;height:42px; background:linear-gradient(to bottom,rgba(193,144,208,.5),transparent); animation:lp-scroll-bar 2s ease-in-out infinite; }
@keyframes lp-scroll-bar { 0%{transform:scaleY(0);transform-origin:top} 50%{transform:scaleY(1);transform-origin:top} 50.01%{transform:scaleY(1);transform-origin:bottom} 100%{transform:scaleY(0);transform-origin:bottom} }

/* ═══════════════════════════════════════════════════════════════
   2. PAIN POINT
═══════════════════════════════════════════════════════════════ */
#vlp-pain-{{ section.id }} {
  background: var(--lp-white);
  padding: 7rem 2rem;
}
.lp-pain-inner {
  max-width:1200px; margin:0 auto;
}
.lp-pain-quote {
  font-family:var(--lp-font-h);
  font-size:clamp(2rem,4vw,3.6rem);
  font-weight:300;
  font-style:italic;
  color:var(--lp-black);
  line-height:1.2;
  text-align:center;
  max-width:20ch;
  margin:0 auto 1.6rem;
}
.lp-pain-quote em { color:var(--lp-deep); font-style:normal; }
.lp-pain-sub {
  text-align:center;
  font-size:.96rem;
  color:var(--lp-stone);
  max-width:48ch;
  margin:0 auto 5rem;
  line-height:1.72;
}
.lp-pain-cards {
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:1.6rem;
}
.lp-pain-card {
  background:var(--lp-lavender-soft, #F2E8F7);
  border-radius:20px;
  padding:2.4rem 2rem;
  border:1px solid rgba(193,144,208,.2);
  transition:all .3s var(--lp-ease);
}
.lp-pain-card:hover {
  transform:translateY(-4px);
  box-shadow:0 14px 48px rgba(122,74,154,.12);
  border-color:rgba(193,144,208,.45);
}
.lp-pain-card__icon {
  width:44px; height:44px;
  background:rgba(193,144,208,.18);
  border-radius:12px;
  display:flex; align-items:center; justify-content:center;
  margin-bottom:1.2rem;
  color:var(--lp-deep);
}
.lp-pain-card__title {
  font-family:var(--lp-font-h);
  font-size:1.5rem;
  font-weight:400;
  color:var(--lp-black);
  margin-bottom:.6rem;
  line-height:1.2;
}
.lp-pain-card__text { font-size:.88rem; line-height:1.72; color:var(--lp-stone); }

/* ═══════════════════════════════════════════════════════════════
   3. SOLUTION
═══════════════════════════════════════════════════════════════ */
#vlp-solution-{{ section.id }} {
  background:linear-gradient(150deg, #7A4A9A 0%, #A568C0 45%, #C190D0 100%);
  padding:7rem 2rem;
  position:relative;
  overflow:hidden;
}
#vlp-solution-{{ section.id }}::after {
  content:'';
  position:absolute; inset:0;
  background:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E") 180px / 180px;
  opacity:.028;
  pointer-events:none;
}
.lp-solution-inner {
  position:relative; z-index:1;
  max-width:1200px; margin:0 auto;
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:5rem;
  align-items:center;
}
.lp-solution-img-wrap {
  position:relative;
  display:flex; align-items:center; justify-content:center;
}
.lp-solution-img-glow {
  position:absolute; width:380px;height:380px;border-radius:50%;
  background:rgba(255,255,255,.1);
  filter:blur(60px);
  animation:lp-glow 5s ease-in-out infinite;
}
.lp-solution-img {
  width:100%; max-width:340px; height:auto;
  filter:drop-shadow(0 24px 60px rgba(13,11,14,.35));
  animation:lp-float 6s ease-in-out infinite;
  position:relative; z-index:1;
}
.lp-solution-img-placeholder { width:100%; max-width:280px; opacity:.3; }
.lp-solution-content { }
.lp-solution-checks { list-style:none; padding:0; margin:2rem 0 2.8rem; display:flex; flex-direction:column; gap:.8rem; }
.lp-solution-check {
  display:flex; align-items:flex-start; gap:.8rem;
  font-size:.92rem; color:rgba(255,255,255,.8); line-height:1.5;
}
.lp-check-icon {
  flex-shrink:0; width:20px; height:20px; margin-top:1px;
  background:rgba(255,255,255,.15);
  border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  color:var(--lp-white);
}

/* ═══════════════════════════════════════════════════════════════
   4. HOW IT WORKS
═══════════════════════════════════════════════════════════════ */
#vlp-how-{{ section.id }} { background:var(--lp-lavender-soft, #F2E8F7); padding:7rem 2rem; }
.lp-how-inner { max-width:1100px; margin:0 auto; }
.lp-how-header { text-align:center; margin-bottom:5rem; }
.lp-steps {
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:2.4rem;
  position:relative;
}
/* Connecting line */
.lp-steps::before {
  content:'';
  position:absolute;
  top:44px; left:calc(16.66% + 1rem);
  width:calc(66.66% - 2rem);
  height:1px;
  background:linear-gradient(90deg, var(--lp-lavender) 0%, var(--lp-deep) 100%);
  opacity:.35;
}
.lp-step { text-align:center; padding:0 1rem; }
.lp-step-num {
  width:56px; height:56px; border-radius:50%;
  background:linear-gradient(135deg, var(--lp-lavender) 0%, var(--lp-deep) 100%);
  display:flex; align-items:center; justify-content:center;
  margin:0 auto 1.6rem;
  font-family:var(--lp-font-h);
  font-size:1.4rem; font-weight:400; color:var(--lp-white);
  position:relative; z-index:1;
  box-shadow:0 8px 24px rgba(122,74,154,.3);
  transition:transform .3s ease, box-shadow .3s ease;
}
.lp-step:hover .lp-step-num {
  transform:scale(1.08);
  box-shadow:0 14px 36px rgba(122,74,154,.45);
}
.lp-step-title {
  font-family:var(--lp-font-h);
  font-size:1.5rem; font-weight:400;
  color:var(--lp-black); margin-bottom:.6rem;
}
.lp-step-text { font-size:.88rem; line-height:1.72; color:var(--lp-stone); }

/* ═══════════════════════════════════════════════════════════════
   5. INGREDIENTS
═══════════════════════════════════════════════════════════════ */
