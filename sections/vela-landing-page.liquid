{% comment %}VELA — Full Funnel Landing Page{% endcomment %}

<style>
  #vlp-{{ section.id }} {
    font-family:'DM Sans',system-ui,sans-serif;
    color:#1E1A22;overflow-x:hidden;
    --lp-lav:#C190D0;--lp-deep:#7A4A9A;--lp-black:#0A0810;--lp-white:#fff;
    --ease:cubic-bezier(0.22,1,0.36,1);
  }
  #vlp-{{ section.id }} .lp-reveal { opacity:0;transform:translateY(28px);transition:opacity 0.7s var(--ease),transform 0.7s var(--ease); }
  #vlp-{{ section.id }} .lp-reveal.on { opacity:1;transform:none; }
  #vlp-{{ section.id }} [data-d="1"]{transition-delay:0.08s}
  #vlp-{{ section.id }} [data-d="2"]{transition-delay:0.16s}
  #vlp-{{ section.id }} [data-d="3"]{transition-delay:0.24s}
  /* HERO */
  #vlp-hero-{{ section.id }} {
    background:#0A0810;min-height:100svh;display:flex;align-items:center;
    position:relative;overflow:hidden;
  }
  #vlp-{{ section.id }} .lp-orb {
    position:absolute;border-radius:50%;filter:blur(90px);pointer-events:none;
    animation:lp-drift 9s ease-in-out infinite;
  }
  #vlp-{{ section.id }} .lp-orb-a{width:500px;height:500px;background:rgba(193,144,208,0.16);top:-15%;left:-10%}
  #vlp-{{ section.id }} .lp-orb-b{width:360px;height:360px;background:rgba(122,74,154,0.2);bottom:0;right:0;animation-delay:-4s}
  @keyframes lp-drift{0%,100%{transform:translateY(0)}50%{transform:translateY(-24px)}}
  #vlp-{{ section.id }} .lp-hero-in {
    position:relative;z-index:2;max-width:1300px;margin:0 auto;padding:6rem 5%;
    display:grid;grid-template-columns:1fr 1fr;align-items:center;gap:3rem;width:100%;box-sizing:border-box;
  }
  #vlp-{{ section.id }} .lp-h1 {
    font-family:'Cormorant Garamond',Georgia,serif;
    font-size:clamp(2.8rem,5vw,5.2rem);font-weight:300;line-height:1.04;
    color:#fff;margin:0 0 1.4rem;max-width:13ch;
  }
  #vlp-{{ section.id }} .lp-h1 em{color:#C190D0;font-style:italic}
  #vlp-{{ section.id }} .lp-hero-p{font-size:0.97rem;line-height:1.78;color:rgba(255,255,255,0.52);margin:0 0 2.2rem;max-width:42ch}
  #vlp-{{ section.id }} .lp-btn {
    display:inline-flex;align-items:center;gap:8px;
    background:linear-gradient(135deg,#7A4A9A,#C190D0);
    color:#fff;font-size:0.82rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;
    text-decoration:none;padding:15px 32px;border-radius:100px;
    box-shadow:0 8px 32px rgba(193,144,208,0.3);
    transition:transform 0.2s,box-shadow 0.2s;
  }
  #vlp-{{ section.id }} .lp-btn:hover{transform:translateY(-2px);box-shadow:0 14px 40px rgba(193,144,208,0.45)}
  #vlp-{{ section.id }} .lp-proof{display:flex;align-items:center;gap:10px;margin-top:1.8rem;font-size:0.75rem;color:rgba(255,255,255,0.38)}
  #vlp-{{ section.id }} .lp-stars{color:#C190D0}
  #vlp-{{ section.id }} .lp-hero-img{display:flex;justify-content:center;position:relative}
  #vlp-{{ section.id }} .lp-hero-img img,.lp-hero-img svg{max-height:500px;width:100%;object-fit:contain;animation:lp-float 5s ease-in-out infinite}
  #vlp-{{ section.id }} .lp-glow{position:absolute;width:320px;height:320px;border-radius:50%;background:radial-gradient(circle,rgba(193,144,208,0.18),transparent 70%)}
  @keyframes lp-float{0%,100%{transform:translateY(0)}50%{transform:translateY(-14px)}}
  /* PAIN */
  #vlp-pain-{{ section.id }}{padding:7rem 5%;background:#fff;text-align:center}
  #vlp-{{ section.id }} .lp-eyebrow{font-size:0.62rem;font-weight:700;letter-spacing:0.26em;text-transform:uppercase;color:#7A4A9A;margin-bottom:1.2rem;display:block}
  #vlp-{{ section.id }} .lp-h2{font-family:'Cormorant Garamond',Georgia,serif;font-size:clamp(2.2rem,4vw,3.8rem);font-weight:300;line-height:1.1;margin:0 auto 1.2rem;max-width:18ch}
  #vlp-{{ section.id }} .lp-sub{font-size:0.96rem;line-height:1.76;color:#9B8FA3;max-width:52ch;margin:0 auto 3.5rem}
  #vlp-{{ section.id }} .lp-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;max-width:1100px;margin:0 auto}
  #vlp-{{ section.id }} .lp-card{background:#FAF8FC;border-radius:16px;padding:2.2rem 1.8rem;text-align:left}
  #vlp-{{ section.id }} .lp-card-icon{font-size:2rem;margin-bottom:1rem}
  #vlp-{{ section.id }} .lp-card-h{font-weight:700;font-size:0.95rem;margin-bottom:0.5rem;color:#1E1A22}
  #vlp-{{ section.id }} .lp-card-p{font-size:0.88rem;line-height:1.7;color:#9B8FA3}
  /* SOLUTION */
  #vlp-sol-{{ section.id }}{padding:7rem 5%;background:linear-gradient(150deg,#7A4A9A,#A568C0,#C190D0)}
  #vlp-{{ section.id }} .lp-sol-in{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center;max-width:1200px;margin:0 auto}
  #vlp-{{ section.id }} .lp-sol-img{display:flex;justify-content:center}
  #vlp-{{ section.id }} .lp-sol-img img,.lp-sol-img svg{max-height:460px;width:100%;object-fit:contain;border-radius:24px}
  #vlp-{{ section.id }} .lp-check{display:flex;gap:12px;align-items:flex-start;margin-bottom:1.4rem}
  #vlp-{{ section.id }} .lp-check-icon{width:22px;height:22px;border-radius:50%;background:rgba(255,255,255,0.2);display:flex;align-items:center;justify-content:center;flex-shrink:0;color:#fff;font-size:0.75rem;margin-top:2px}
  #vlp-{{ section.id }} .lp-check-t{font-weight:600;color:#fff;font-size:0.95rem;margin-bottom:0.2rem}
  #vlp-{{ section.id }} .lp-check-p{font-size:0.85rem;color:rgba(255,255,255,0.65);line-height:1.6}
  /* HOW */
  #vlp-how-{{ section.id }}{padding:7rem 5%;background:#F9F6FC;text-align:center}
  #vlp-{{ section.id }} .lp-steps{display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;max-width:1000px;margin:2.5rem auto 0;position:relative}
  #vlp-{{ section.id }} .lp-step{padding:2rem 1.5rem}
  #vlp-{{ section.id }} .lp-step-num{width:52px;height:52px;border-radius:50%;background:linear-gradient(135deg,#7A4A9A,#C190D0);color:#fff;font-family:'Cormorant Garamond',serif;font-size:1.4rem;font-weight:300;display:flex;align-items:center;justify-content:center;margin:0 auto 1.2rem}
  #vlp-{{ section.id }} .lp-step-h{font-weight:700;font-size:0.95rem;margin-bottom:0.5rem;color:#1E1A22}
  #vlp-{{ section.id }} .lp-step-p{font-size:0.88rem;line-height:1.7;color:#9B8FA3}
  /* CTA */
  #vlp-cta-{{ section.id }}{padding:7rem 5%;background:#0A0810;text-align:center;position:relative;overflow:hidden}
  #vlp-{{ section.id }} .lp-cta-orb{position:absolute;border-radius:50%;filter:blur(80px);pointer-events:none}
  #vlp-{{ section.id }} .lp-cta-orb-a{width:400px;height:400px;background:rgba(193,144,208,0.15);top:-20%;left:-10%}
  #vlp-{{ section.id }} .lp-cta-orb-b{width:300px;height:300px;background:rgba(122,74,154,0.2);bottom:-10%;right:5%}
  #vlp-{{ section.id }} .lp-cta-in{position:relative;z-index:2}
  #vlp-{{ section.id }} .lp-cta-h{font-family:'Cormorant Garamond',Georgia,serif;font-size:clamp(2.4rem,4.5vw,4rem);font-weight:300;color:#fff;margin:0 auto 1rem;max-width:20ch}
  #vlp-{{ section.id }} .lp-cta-h em{color:#C190D0;font-style:italic}
  #vlp-{{ section.id }} .lp-cta-p{font-size:0.97rem;color:rgba(255,255,255,0.5);margin:0 auto 2.5rem;max-width:50ch}
  #vlp-{{ section.id }} .lp-trust{display:flex;justify-content:center;gap:2rem;flex-wrap:wrap;margin-top:1.8rem}
  #vlp-{{ section.id }} .lp-trust-item{font-size:0.75rem;color:rgba(255,255,255,0.38);display:flex;align-items:center;gap:6px}
  @media(max-width:768px){
    #vlp-{{ section.id }} .lp-hero-in,#vlp-{{ section.id }} .lp-sol-in{grid-template-columns:1fr}
    #vlp-{{ section.id }} .lp-hero-img,#vlp-{{ section.id }} .lp-sol-img{display:none}
    #vlp-{{ section.id }} .lp-cards,#vlp-{{ section.id }} .lp-steps{grid-template-columns:1fr}
    #vlp-{{ section.id }} .lp-trust{gap:1rem}
  }
</style>

<div id="vlp-{{ section.id }}">

<!-- HERO -->
<section id="vlp-hero-{{ section.id }}">
  <div class="lp-orb lp-orb-a" aria-hidden="true"></div>
  <div class="lp-orb lp-orb-b" aria-hidden="true"></div>
  <div class="lp-hero-in">
    <div>
      <span class="lp-eyebrow lp-reveal">{{ section.settings.hero_eyebrow | default: 'Introducing Vela' }}</span>
      <h1 class="lp-h1 lp-reveal" data-d="1">{{ section.settings.hero_headline | default: 'Modern life is relentless. Your body <em>remembers.</em>' }}</h1>
      <p class="lp-hero-p lp-reveal" data-d="2">{{ section.settings.hero_desc | default: 'Reishi Calm Drops is a daily adaptogen tincture crafted to quiet the noise — supporting your body\'s natural stress response.' }}</p>
      <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="lp-btn lp-reveal" data-d="3">
        {{ section.settings.cta_text | default: 'Shop Reishi Calm Drops' }}
      </a>
      <div class="lp-proof lp-reveal" data-d="3">
        <span class="lp-stars">★★★★★</span>
        <span>{{ section.settings.review_count | default: 2847 }} verified reviews &middot; {{ section.settings.proof_badge | default: 'Natural formula' }}</span>
      </div>
    </div>
    <div class="lp-hero-img" aria-hidden="true">
      <div class="lp-glow"></div>
      {%- if section.settings.hero_image != blank -%}
        <img src="{{ section.settings.hero_image | image_url: width: 600 }}" alt="{{ section.settings.hero_image.alt | escape }}" width="600" loading="eager">
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag }}
      {%- endif -%}
    </div>
  </div>
</section>

<!-- PAIN POINT -->
<section id="vlp-pain-{{ section.id }}">
  <span class="lp-eyebrow lp-reveal">The problem</span>
  <h2 class="lp-h2 lp-reveal" data-d="1">You're not broken.<br>You're <em style="color:#7A4A9A;font-style:italic">overwhelmed.</em></h2>
  <p class="lp-sub lp-reveal" data-d="2">Modern stress doesn't announce itself — it accumulates in your body until it becomes something you just live with. Until now.</p>
  <div class="lp-cards">
    <div class="lp-card lp-reveal"><div class="lp-card-icon">🌙</div><div class="lp-card-h">Restless nights</div><p class="lp-card-p">Your mind won't stop running. You lie awake at 2am replaying everything you need to do tomorrow.</p></div>
    <div class="lp-card lp-reveal" data-d="1"><div class="lp-card-icon">⚡</div><div class="lp-card-h">Constant tension</div><p class="lp-card-p">Your shoulders are always up by your ears. Your jaw is clenched. Your body is in fight mode even when you're sitting still.</p></div>
    <div class="lp-card lp-reveal" data-d="2"><div class="lp-card-icon">🌫️</div><div class="lp-card-h">Mental fog</div><p class="lp-card-p">Concentration slips away. You read the same sentence three times. The clarity you used to have feels out of reach.</p></div>
  </div>
</section>

<!-- SOLUTION -->
<section id="vlp-sol-{{ section.id }}">
  <div class="lp-sol-in">
    <div class="lp-sol-img lp-reveal">
      {%- if section.settings.solution_image != blank -%}
        <img src="{{ section.settings.solution_image | image_url: width: 600 }}" alt="{{ section.settings.solution_image.alt | escape }}" width="600" loading="lazy">
      {%- else -%}
        {{ 'product-2' | placeholder_svg_tag }}
      {%- endif -%}
    </div>
    <div>
      <span class="lp-eyebrow lp-reveal" style="color:rgba(255,255,255,0.6)">The solution</span>
      <h2 class="lp-h2 lp-reveal" data-d="1" style="color:#fff;max-width:16ch">Nature's answer to modern stress</h2>
      <div style="margin-top:2rem">
        <div class="lp-check lp-reveal" data-d="1"><div class="lp-check-icon">✓</div><div><div class="lp-check-t">Clinically studied Reishi mushroom</div><p class="lp-check-p">Adaptogenic compounds that help your body regulate its stress response naturally.</p></div></div>
        <div class="lp-check lp-reveal" data-d="2"><div class="lp-check-icon">✓</div><div><div class="lp-check-t">Ashwagandha + Lion's Mane</div><p class="lp-check-p">A synergistic blend that supports mental clarity and sustained calm throughout the day.</p></div></div>
        <div class="lp-check lp-reveal" data-d="3"><div class="lp-check-icon">✓</div><div><div class="lp-check-t">Fast-absorbing liquid formula</div><p class="lp-check-p">Sublingual drops absorb up to 5× faster than capsules. Feel it in minutes, not hours.</p></div></div>
        <div class="lp-check lp-reveal" data-d="3"><div class="lp-check-icon">✓</div><div><div class="lp-check-t">No melatonin. No sedatives.</div><p class="lp-check-p">Just pure plant intelligence — calming without clouding. Energizing without wiring.</p></div></div>
      </div>
      <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="lp-btn lp-reveal" data-d="3" style="margin-top:2rem;background:rgba(255,255,255,0.15);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,0.25)">
        {{ section.settings.cta_text | default: 'Shop Reishi Calm Drops' }}
      </a>
    </div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section id="vlp-how-{{ section.id }}">
  <span class="lp-eyebrow lp-reveal">How it works</span>
  <h2 class="lp-h2 lp-reveal" data-d="1">Three steps to calm</h2>
  <div class="lp-steps">
    <div class="lp-step lp-reveal"><div class="lp-step-num">1</div><div class="lp-step-h">Drop it under your tongue</div><p class="lp-step-p">Place a full dropper (1ml) under your tongue and hold for 30–60 seconds for maximum absorption.</p></div>
    <div class="lp-step lp-reveal" data-d="1"><div class="lp-step-num">2</div><div class="lp-step-h">Let the adaptogens work</div><p class="lp-step-p">Reishi and Ashwagandha begin modulating your cortisol response within minutes of absorption.</p></div>
    <div class="lp-step lp-reveal" data-d="2"><div class="lp-step-num">3</div><div class="lp-step-h">Feel the shift</div><p class="lp-step-p">A quieter mind. A looser jaw. The kind of calm that lets you be present — not checked out.</p></div>
  </div>
</section>

<!-- CTA -->
<section id="vlp-cta-{{ section.id }}">
  <div class="lp-cta-orb lp-cta-orb-a" aria-hidden="true"></div>
  <div class="lp-cta-orb lp-cta-orb-b" aria-hidden="true"></div>
  <div class="lp-cta-in">
    <h2 class="lp-cta-h lp-reveal">You deserve to feel <em>calm</em> again.</h2>
    <p class="lp-cta-p lp-reveal" data-d="1">Join thousands who've made Reishi Calm Drops part of their daily ritual. Backed by a 30-day guarantee.</p>
    <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="lp-btn lp-reveal" data-d="2">
      {{ section.settings.cta_text | default: 'Shop Reishi Calm Drops' }}
    </a>
    <div class="lp-trust lp-reveal" data-d="3">
      <span class="lp-trust-item">✓ 30-day guarantee</span>
      <span class="lp-trust-item">✓ Free shipping over $50</span>
      <span class="lp-trust-item">✓ Made in USA</span>
      <span class="lp-trust-item">✓ No subscription required</span>
    </div>
  </div>
</section>

</div>

<script>
(function(){
  var root = document.getElementById('vlp-{{ section.id }}');
  if(!root) return;
  var io = new IntersectionObserver(function(entries){
    entries.forEach(function(e){ if(e.isIntersecting){e.target.classList.add('on');io.unobserve(e.target);} });
  },{threshold:0.1,rootMargin:'0px 0px -40px 0px'});
  root.querySelectorAll('.lp-reveal').forEach(function(el){io.observe(el);});
})();
</script>

{% schema %}
{
  "name": "Vela Landing Page",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text",         "id": "hero_eyebrow",  "label": "Hero eyebrow",   "default": "Introducing Vela" },
    { "type": "textarea",     "id": "hero_headline", "label": "Hero headline",  "default": "Modern life is relentless. Your body remembers." },
    { "type": "textarea",     "id": "hero_desc",     "label": "Hero description","default": "Reishi Calm Drops is a daily adaptogen tincture crafted to quiet the noise." },
    { "type": "image_picker", "id": "hero_image",    "label": "Hero product image" },
    { "type": "image_picker", "id": "solution_image","label": "Solution section image" },
    { "type": "url",          "id": "cta_url",       "label": "Shop button URL" },
    { "type": "text",         "id": "cta_text",      "label": "Shop button text","default": "Shop Reishi Calm Drops" },
    { "type": "number",       "id": "review_count",  "label": "Review count",   "default": 2847 },
    { "type": "text",         "id": "proof_badge",   "label": "Trust badge",    "default": "Natural formula" }
  ],
  "presets": [{ "name": "Vela Landing Page" }]
}
{% endschema %}
