  .lp-hero-glow { width:300px;height:300px; }
  .lp-hero-badge { display:none; }
  .lp-scroll-cue { display:none; }
  .lp-pain-cards { grid-template-columns:1fr; }
  .lp-solution-inner { grid-template-columns:1fr; text-align:center; gap:3rem; }
