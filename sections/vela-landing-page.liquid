  pointer-events:none; filter:blur(100px);
}
.lp-cta-orb--1 { width:500px;height:500px;background:radial-gradient(circle,#7A4A9A,transparent 70%); top:-20%;left:-5%;opacity:.7;animation:lp-float-a 22s ease-in-out infinite; }
.lp-cta-orb--2 { width:400px;height:400px;background:radial-gradient(circle,#C190D0,transparent 70%); bottom:-15%;right:-5%;opacity:.55;animation:lp-float-b 18s ease-in-out infinite; }

.lp-cta-inner { max-width:700px; margin:0 auto; position:relative; z-index:1; }
