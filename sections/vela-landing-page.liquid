  .lp-ingr-feature { position:static; }
  .lp-testi-grid { grid-template-columns:1fr; }
  .lp-testi-summary { gap:2rem; }
}
@media (max-width:480px) {
  .lp-hero-h1 { font-size:2.8rem; }
